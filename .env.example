# Twilio Account Credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Verify Service (for sending test verifications)
VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook Configuration
WEBHOOK_URL=https://your-domain.ngrok.io/events
PORT=3000

# Event Stream Configuration (created by setup script)
EVENT_SINK_SID=
EVENT_SUBSCRIPTION_SID=
